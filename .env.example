NEXT_PUBLIC_APP_URL=https://similaritycheck.genevidence.com
NEXT_PUBLIC_SITE_URL=https://similaritycheck.genevidence.com
NEXT_PUBLIC_API_BASE_URL=https://api-similaritycheck.genevidence.com
APP_NAME="Genevidence Similarity Check"

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@DATABASE_HOST:5432/DATABASE_NAME
REDIS_URL=rediss://USER:PASSWORD@REDIS_HOST:6379/0
JWT_SECRET=generate-a-long-random-secret-for-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
MAX_UPLOAD_MB=25
STORAGE_DIR=/var/lib/genevidence/documents
BACKEND_CORS_ORIGINS=https://similaritycheck.genevidence.com
AUTO_CREATE_TABLES=false

CHUNK_SIZE_WORDS=150
CHUNK_OVERLAP_WORDS=30
EXACT_NGRAM_SIZE=5
WINNOW_K_GRAM_SIZE=5
WINNOW_WINDOW_SIZE=4
JACCARD_THRESHOLD=0.18
FUZZY_THRESHOLD=82

SEMANTIC_ENABLED=false
SEMANTIC_MODEL_NAME=intfloat/multilingual-e5-base
SEMANTIC_EMBEDDING_DIMENSIONS=768
SEMANTIC_COSINE_THRESHOLD=0.86
SEMANTIC_MIN_WORDS=60
